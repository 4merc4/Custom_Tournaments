@model Custom_Tournaments.Domain.Model.Tournament

@{
    ViewData["Title"] = "Видалити турнір";
}

<div class="page-hero">
    <div class="container">
        <h2 class="fw-bold mb-0 text-danger"><i class="bi bi-trash me-2"></i>Видалити турнір</h2>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-danger" style="border-color: rgba(255,99,99,0.4) !important;">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-exclamation-triangle-fill text-danger fs-1 mb-3 d-block"></i>
                    <h5 class="mb-1">Ви впевнені?</h5>
                    <p class="text-muted mb-3">
                        Турнір <strong>«@Model.Title»</strong> та всі пов'язані учасники будуть видалені назавжди.
                    </p>

                    <dl class="text-start mb-4">
                        @if (!string.IsNullOrEmpty(Model.Gamename))
                        {
                            <dt class="text-muted small">Гра</dt>
                            <dd>@Model.Gamename</dd>
                        }
                        <dt class="text-muted small">Організатор</dt>
                        <dd>@Model.Organizer?.Username</dd>
                        <dt class="text-muted small">Команд-учасників</dt>
                        <dd>@Model.Tournamentparticipants.Count</dd>
                    </dl>

                    <div class="d-flex gap-2 justify-content-center">
                        <form asp-action="Delete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Так, видалити
                            </button>
                        </form>
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
