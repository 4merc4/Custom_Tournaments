@model IEnumerable<Custom_Tournaments.Domain.Model.Tournament>

@{
    ViewData["Title"] = "Головна";
}

<div class="page-hero">
    <div class="container">
        <h1 class="fw-bold mb-1"><i class="bi bi-trophy-fill me-2 text-warning"></i>Custom Tournaments</h1>
        <p class="text-muted mb-0">Знаходь турніри, збирай команди, змагайся</p>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Публічні турніри</h4>
        <a asp-controller="Tournaments" asp-action="Index" class="btn btn-outline-primary btn-sm">
            Всі турніри <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
            <p>Публічних турнірів поки немає</p>
            <a asp-controller="Tournaments" asp-action="Create" class="btn btn-primary">Створити перший</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var tournament in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title mb-0 fw-semibold">@tournament.Title</h6>
                                <span class="badge-public ms-2 flex-shrink-0">Публічний</span>
                            </div>
                            @if (!string.IsNullOrEmpty(tournament.Gamename))
                            {
                                <div class="mb-2">
                                    <span class="badge-game"><i class="bi bi-controller me-1"></i>@tournament.Gamename</span>
                                </div>
                            }
                            <div class="text-muted small mb-3">
                                <i class="bi bi-person me-1"></i>@tournament.Organizer?.Username
                                @if (tournament.Prizepool.HasValue && tournament.Prizepool > 0)
                                {
                                    <span class="ms-3"><i class="bi bi-cash me-1"></i>@tournament.Prizepool.Value.ToString("N0") грн</span>
                                }
                            </div>
                            <a asp-controller="Tournaments" asp-action="Details" asp-route-id="@tournament.Id"
                                   class="btn btn-outline-primary btn-sm w-100">
                                Детальніше
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
