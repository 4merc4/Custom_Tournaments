@model Custom_Tournaments_Infrastructure.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
}

<div class="page-hero">
    <div class="container">
        <h2 class="fw-bold mb-0"><i class="bi bi-person-plus me-2"></i>Реєстрація</h2>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        @if (ViewBag.DebugErrors != null)
                        {
                            <div class="alert alert-danger">@ViewBag.DebugErrors</div>
                        }

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">Нікнейм</label>
                            <input asp-for="Username" class="form-control" placeholder="Ваш нікнейм..." />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Пароль</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Мінімум 6 символів" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Підтвердження паролю</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Повторіть пароль" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-person-check me-1"></i>Зареєструватися
                        </button>

                        <div class="text-center mt-3">
                            <small style="color: var(--ct-muted);">
                                Вже є акаунт?
                                <a asp-action="Login" style="color: var(--ct-accent);">Увійти</a>
                            </small>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
