<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Custom Tournaments</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
            :root {
                --ct-dark: #0f1117;
                --ct-card: #1a1d27;
                --ct-border: #2a2d3e;
                --ct-accent: #6c63ff;
                --ct-accent-hover: #5a52d5;
                --ct-text: #e2e8f0;
                --ct-muted: #8892a4;
            }

            html, body {
                width: 100%;
                margin: 0;
                padding: 0;
                display: flex;
                flex-direction: column;
            }

            body {
                background-color: var(--ct-dark);
                color: var(--ct-text);
                font-family: 'Segoe UI', sans-serif;
                min-height: 100vh;
            }

            main {
                flex: 1;
                width: 100%;
            }

            .container {
                max-width: 1400px;
                width: 100%;
            }

            .navbar {
                background-color: var(--ct-card) !important;
                border-bottom: 1px solid var(--ct-border);
            }

            .navbar-brand {
                font-weight: 700;
                font-size: 1.3rem;
                color: var(--ct-accent) !important;
                letter-spacing: 0.5px;
            }

            .nav-link {
                color: var(--ct-muted) !important;
                transition: color 0.2s;
            }

                .nav-link:hover, .nav-link.active {
                    color: var(--ct-text) !important;
                }

            .card {
                background-color: var(--ct-card);
                border: 1px solid var(--ct-border);
                border-radius: 12px;
            }

            .card-header {
                background-color: transparent;
                border-bottom: 1px solid var(--ct-border);
                font-weight: 600;
                color: var(--ct-text) !important;
            }

            .btn-primary {
                background-color: var(--ct-accent);
                border-color: var(--ct-accent);
            }

                .btn-primary:hover {
                    background-color: var(--ct-accent-hover);
                    border-color: var(--ct-accent-hover);
                }

            .btn-outline-primary {
                color: var(--ct-accent);
                border-color: var(--ct-accent);
            }

                .btn-outline-primary:hover {
                    background-color: var(--ct-accent);
                    border-color: var(--ct-accent);
                    color: white;
                }

            .form-control, .form-select {
                background-color: #252836;
                border: 1px solid var(--ct-border);
                color: var(--ct-text);
            }

                .form-control:focus, .form-select:focus {
                    background-color: #252836;
                    border-color: var(--ct-accent);
                    color: var(--ct-text);
                    box-shadow: 0 0 0 0.2rem rgba(108, 99, 255, 0.25);
                }

                .form-control::placeholder {
                    color: var(--ct-muted);
                }

            .table {
                color: var(--ct-text);
            }

                .table > :not(caption) > * > * {
                    background-color: transparent;
                    border-color: var(--ct-border);
                }

            .badge-game {
                background-color: rgba(108, 99, 255, 0.15);
                color: var(--ct-accent);
                border: 1px solid rgba(108, 99, 255, 0.3);
                border-radius: 6px;
                padding: 3px 10px;
                font-size: 0.78rem;
            }

            .badge-private {
                background-color: rgba(255, 99, 99, 0.15);
                color: #ff6363;
                border: 1px solid rgba(255, 99, 99, 0.3);
                border-radius: 6px;
                padding: 3px 10px;
                font-size: 0.78rem;
            }

            .badge-public {
                background-color: rgba(99, 255, 162, 0.15);
                color: #63ffb4;
                border: 1px solid rgba(99, 255, 162, 0.3);
                border-radius: 6px;
                padding: 3px 10px;
                font-size: 0.78rem;
            }

            .badge-planned {
                background-color: rgba(255, 193, 7, 0.15);
                color: #ffc107;
                border: 1px solid rgba(255, 193, 7, 0.3);
                border-radius: 6px;
                padding: 3px 10px;
                font-size: 0.78rem;
            }

            .badge-ongoing {
                background-color: rgba(13, 202, 240, 0.15);
                color: #0dcaf0;
                border: 1px solid rgba(13, 202, 240, 0.3);
                border-radius: 6px;
                padding: 3px 10px;
                font-size: 0.78rem;
            }

            .badge-finished {
                background-color: rgba(99, 255, 162, 0.15);
                color: #63ffb4;
                border: 1px solid rgba(99, 255, 162, 0.3);
                border-radius: 6px;
                padding: 3px 10px;
                font-size: 0.78rem;
            }

            .team-logo {
                width: 48px;
                height: 48px;
                object-fit: cover;
                border-radius: 8px;
                flex-shrink: 0;
                display: block;
            }

            .team-logo-placeholder {
                width: 48px;
                height: 48px;
                background-color: var(--ct-border);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--ct-muted);
                font-size: 1.4rem;
                flex-shrink: 0;
            }

            footer {
                background-color: var(--ct-card);
                border-top: 1px solid var(--ct-border);
                color: var(--ct-muted);
            }

            .page-hero {
                background: linear-gradient(135deg, rgba(108, 99, 255, 0.15) 0%, transparent 60%);
                border-bottom: 1px solid var(--ct-border);
                padding: 2rem 0;
                margin-bottom: 2rem;
            }

            .card-body, .card-body p, .card-body dd,
            .card-body small, .list-group-item, h6, h5, h4 {
                color: var(--ct-text) !important;
            }

                .card-body dt, label, .form-label, .breadcrumb-item {
                    color: var(--ct-muted) !important;
                }

                .card-body dd, h1, h2, h3, h4, h5, h6,
                .fw-semibold, .fw-bold, .card-title, .form-check-label {
                    color: var(--ct-text) !important;
                }

            .text-muted {
                color: var(--ct-muted) !important;
            }

            .form-text {
                color: var(--ct-text) !important;
            }

            .navbar-user {
                display: flex;
                align-items: center;
                gap: 8px;
                color: var(--ct-text);
                font-size: 0.9rem;
            }

                .navbar-user .avatar {
                    width: 30px;
                    height: 30px;
                    border-radius: 50%;
                    background-color: var(--ct-accent);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 0.75rem;
                    font-weight: 600;
                    color: white;
                }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-trophy-fill me-2"></i>Custom Tournaments
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tournaments" asp-action="Index">
                            <i class="bi bi-trophy me-1"></i>Турніри
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Teams" asp-action="Index">
                            <i class="bi bi-people me-1"></i>Команди
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tournaments" asp-action="Create">
                                <i class="bi bi-plus-circle me-1"></i>Новий турнір
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Teams" asp-action="Create">
                                <i class="bi bi-plus-circle me-1"></i>Нова команда
                            </a>
                        </li>
                        <li class="nav-item">
                            <div class="navbar-user">
                                <div class="avatar">
                                    @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <span style="color: var(--ct-muted); font-size:0.85rem;">@User.Identity.Name</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-box-arrow-right me-1"></i>Вийти
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Увійти
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">
                                <i class="bi bi-person-plus me-1"></i>Реєстрація
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="py-3 mt-5">
        <div class="container text-center">
            <small>&copy; @DateTime.Now.Year Custom Tournaments</small>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
